{
  "name": "pocket-basketball",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "node --test test/*.test.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "install-registry": "npm install --registry=https://registry.npmjs.org/",
    "refresh-lock": "rm -rf node_modules package-lock.json && npm install --registry=https://registry.npmjs.org/"
  },
  "dependencies": {
    "howler": "^2.2.4",
    "matter-js": "^0.20.0"
  },
  "devDependencies": {
    "@types/howler": "^2.2.13",
    "@types/matter-js": "^0.20.2",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.5"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
